# Sentinel Live - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google AI Studio API Key (Required)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_AISTUDIO_KEY=your_api_key_here

# Google Cloud Project Configuration (Required)
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_FIRESTORE_DB=your-firestore-db-name

# Backend URL (Required for Frontend)
# Local development: http://localhost:8000
# Cloud Run: https://sentinel-backend-xxxxx-uc.a.run.app
BACKEND_URL=http://localhost:8000

# Google Cloud Region (Optional)
# Default: us-central1
GOOGLE_CLOUD_REGION=us-central1

# Logging Configuration (Optional)
LOG_LEVEL=INFO
LOG_FILE=server.log

# Development Settings (Optional)
DEBUG=false
ENVIRONMENT=production
